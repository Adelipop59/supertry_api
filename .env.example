# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Testing
BYPASS_BUSINESS_RULES=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/supertry_db

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft (Entra ID)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Countries Configuration
PRIORITY_COUNTRIES=FR
MIN_TESTERS_PER_COUNTRY=10

# Test Accounts (for test scripts with existing accounts)
TEST_PRO_EMAIL=pro-test@example.com
TEST_PRO_PASSWORD=Test1234!
TEST_TESTER_EMAIL=tester-test@example.com
TEST_TESTER_PASSWORD=Test1234!
