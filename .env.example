# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/supertry_db
DIRECT_URL=postgresql://user:password@localhost:5432/supertry_db

# Lucia Auth
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Redis (for Bull queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# S3 Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=eu-central-1
AWS_S3_ENDPOINT=
AWS_S3_BUCKET_NAME=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=
STRIPE_SKIP_SIGNATURE_VERIFICATION=false
SKIP_KYC_VERIFICATION=false

# Stripe Identity
STRIPE_IDENTITY_SECRET_KEY=
STRIPE_IDENTITY_PUBLISHABLE_KEY=
STRIPE_IDENTITY_WEBHOOK_SECRET=

# Bypass Business Rules
BYPASS_BUSINESS_RULES=false

# Test Accounts
TEST_PRO_EMAIL=pro-test@example.com
TEST_PRO_PASSWORD=Test1234!
TEST_TESTER_EMAIL=tester-test@example.com
TEST_TESTER_PASSWORD=Test1234!

# OAuth Providers (optional - enabled when credentials are provided)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft (Entra ID)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# SMTP Email
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=SuperTry
EMAIL_FROM_ADDRESS=noreply@example.com

# Notifications Queue
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5000
NOTIFICATION_QUEUE_CONCURRENCY=5

# Supabase (prod)
PROJECT_URL_PROD=
PUBLISHABLE_KEY_PROD=
DIRECT_CONNECTION_STRING_PROD=

# Supabase (dev)
PROJECT_URL_DEV=
PUBLISHABLE_KEY_DEV=
DIRECT_CONNECTION_STRING_DEV=
